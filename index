<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mini Meet</title>
  <script src="https://cdn.jsdelivr.net/npm/peerjs@1.5.2/dist/peerjs.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0f172a;
      color: white;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      padding: 15px;
      background: #111827;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #1f2937;
    }

    h1 {
      font-size: 22px;
    }

    .controls {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    button, input {
      padding: 10px 14px;
      border-radius: 10px;
      border: none;
      font-size: 14px;
    }

    button {
      cursor: pointer;
      background: #2563eb;
      color: white;
      transition: 0.2s;
    }

    button:hover {
      background: #1d4ed8;
    }

    input {
      background: #1e293b;
      color: white;
      border: 1px solid #334155;
    }

    #videos {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 15px;
      padding: 15px;
    }

    video {
      width: 100%;
      border-radius: 18px;
      background: black;
      border: 2px solid #1e293b;
    }

    .bottomBar {
      background: #111827;
      padding: 15px;
      display: flex;
      justify-content: center;
      gap: 10px;
      border-top: 1px solid #1f2937;
    }

    .danger {
      background: #dc2626;
    }

    .danger:hover {
      background: #b91c1c;
    }

    .green {
      background: #16a34a;
    }

    .green:hover {
      background: #15803d;
    }

    #roomInfo {
      font-size: 14px;
      color: #94a3b8;
      margin-top: 5px;
    }
  </style>
</head>
<body>
  <header>
    <div>
      <h1>Mini Meet</h1>
      <div id="roomInfo">Not connected</div>
    </div>

    <div class="controls">
      <input id="roomInput" placeholder="Room ID" />
      <button onclick="joinRoom()">Join Room</button>
      <button class="green" onclick="createRoom()">Create Room</button>
    </div>
  </header>

  <div id="videos"></div>

  <div class="bottomBar">
    <button onclick="toggleMic()">Mic</button>
    <button onclick="toggleCamera()">Camera</button>
    <button class="danger" onclick="leaveCall()">Leave</button>
  </div>

  <script>
    let localStream;
    let peer;
    let currentCall;
    let roomId = "";
    let micEnabled = true;
    let camEnabled = true;

    const videos = document.getElementById("videos");
    const roomInfo = document.getElementById("roomInfo");

    async function setupMedia() {
      localStream = await navigator.mediaDevices.getUserMedia({
        video: true,
        audio: true,
      });

      addVideo(localStream, true);
    }

    function addVideo(stream, muted = false) {
      const video = document.createElement("video");
      video.srcObject = stream;
      video.autoplay = true;
      video.playsInline = true;
      video.muted = muted;
      videos.appendChild(video);
    }

    async function createRoom() {
      await setupMedia();

      roomId = Math.random().toString(36).substring(2, 8);
      document.getElementById("roomInput").value = roomId;

      startPeer(roomId);

      history.replaceState({}, "", `#${roomId}`);
      roomInfo.innerText = `Room: ${roomId}`;
    }

    async function joinRoom() {
      roomId = document.getElementById("roomInput").value.trim();

      if (!roomId) {
        alert("Enter room ID");
        return;
      }

      await setupMedia();

      const myId = Math.random().toString(36).substring(2, 10);
      startPeer(myId);

      peer.on("open", () => {
        const call = peer.call(roomId, localStream);

        call.on("stream", remoteStream => {
          addVideo(remoteStream);
        });

        currentCall = call;
      });

      roomInfo.innerText = `Connected to: ${roomId}`;
    }

    function startPeer(id) {
      peer = new Peer(id);

      peer.on("call", call => {
        call.answer(localStream);

        call.on("stream", remoteStream => {
          addVideo(remoteStream);
        });

        currentCall = call;
      });
    }

    function toggleMic() {
      micEnabled = !micEnabled;
      localStream.getAudioTracks()[0].enabled = micEnabled;
    }

    function toggleCamera() {
      camEnabled = !camEnabled;
      localStream.getVideoTracks()[0].enabled = camEnabled;
    }

    function leaveCall() {
      if (currentCall) currentCall.close();
      if (peer) peer.destroy();

      videos.innerHTML = "";

      if (localStream) {
        localStream.getTracks().forEach(track => track.stop());
      }

      roomInfo.innerText = "Disconnected";
    }

    window.onload = () => {
      const hashRoom = location.hash.replace("#", "");
      if (hashRoom) {
        document.getElementById("roomInput").value = hashRoom;
      }
    };
  </script>
</body>
</html>
